{
  "name": "RAJPOOT BOT",
  "description": "Javascript WhatsApp bot powered by RAJPOOT HACKER",
  "logo": "https://bandaheali-cdn.koyeb.app/media/bot_1780638419537.jpeg",
  "keywords": [
    "RAJPOOT MD BOT",
    "RAJPOOT",
    "RAJPOOT HACKER",
    "WhatsApp Bot",
    "Baileys Bot",
    "Nodejs Bot"
  ],
  "success_url": "/",
  "stack": "heroku-24",

  "env": {
    "DATABASE_URL": {
      "description": "Paste your MongoDB OR PostgreSQL connection string here. Example: mongodb+srv://... (MongoDB) OR postgresql://... (PostgreSQL / Supabase). If left empty, bot will automatically use local memory database.",
      "required": false
    },

    "OWNER_NUMBER": {
      "description": "Bot owner WhatsApp number without + sign",
      "value": "923253617422",
      "required": true
    },

    "PREFIX": {
      "description": "Command prefix for bot",
      "value": ".",
      "required": false
    },

    "BOT_NAME": {
      "description": "Bot display name",
      "value": "RAJPOOT HACKER",
      "required": false
    },

    "OWNER_NAME": {
      "description": "Bot owner name",
      "value": "RAJPOOT BOT",
      "required": false
    },

    "CAPTION": {
      "description": "Footer caption used in bot messages",
      "value": "POWERED BY RAJPOOT HACKER",
      "required": false
    },

    "STATUS_MSG": {
      "description": "Bot auto status message",
      "value": "Hello From RAJPOOT HACKER",
      "required": false
    },

    "NEWSLETTER_JID": {
      "description": "WhatsApp newsletter/channel JID",
      "value": "120363409334515162@newsletter",
      "required": false
    },

    "MENU_IMG": {
      "description": "Menu image URL",
      "value": "https://bandaheali-cdn.koyeb.app/media/bot_1780638419537.jpeg",
      "required": false
    },

    "SITE_URL": {
      "description": "Pairing website URL",
      "value": "https://smd-mini.vercel.app",
      "required": false
    },

    "PORT": {
      "description": "Server port (optional)",
      "required": false
    }
  },

  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-nodejs.git"
    }
  ]
}
